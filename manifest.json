{
  "manifest_version": 3,
  "name": "Klaviyo Debugger",
  "version": "3.0.6",
  "description": "Diagnose Chronosphere and Splunk calls for flows, campaigns, lists, forms, and push notifications.",
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://klaviyo.chronosphere.io/*",
    "https://klaviyo.splunkcloud.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Klaviyo Debugger"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}