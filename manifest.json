{
  "manifest_version": 3,
  "name": "Klaviyo Flow Debugger",
  "version": "3.0.1",
  "description": "Diagnose why profiles didn't enter flows using Chronosphere & Splunk",
  "permissions": ["sidePanel", "tabs", "scripting", "storage"],
  "host_permissions": [
    "https://klaviyo.chronosphere.io/*",
    "https://klaviyo.splunkcloud.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Klaviyo Flow Debugger"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
